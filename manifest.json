  "shortcuts": [
    {
      "name": "🔥 Trending",
      "short_name": "Trending",
      "description": "View trending content",
      "url": "/?sort=trending",
      "icons": [
        {
          "src": "/assets/images/icons/shortcut-trending.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "📝 Latest Posts",
      "short_name": "Latest",
      "description": "Latest articles and insights",
      "url": "/?sort=latest",
      "icons": [
        {
          "src": "/assets/images/icons/shortcut-latest.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "💻 Technology",
      "short_name": "Tech",
      "description": "Tech news and reviews",
      "url": "/categories/technology/",
      "icons": [
        {
          "src": "/assets/images/icons/shortcut-tech.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "💰 Deals",
      "short_name": "Deals",
      "description": "Exclusive deals and offers",
      "url": "/categories/technology/?filter=deals",
      "icons": [
        {
          "src": "/assets/images/icons/shortcut-deals.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "🔍 Search",
      "short_name": "Search",
      "description": "Search articles",
      "url": "/search/",
      "icons": [
        {
          "src": "/assets/images/icons/shortcut-search.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "📧 Contact",
      "short_name": "Contact",
      "description": "Get in touch",
      "url": "/contact.html",
      "icons": [
        {
          "src": "/assets/images/icons/shortcut-contact.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.trendingwealth.app",
      "id": "com.trendingwealth.app"
    },
    {
      "platform": "itunes",
      "url": "https://apps.apple.com/app/trending-wealth/id1234567890"
    }
  ],
  "prefer_related_applications": false,
  "display_override": ["standalone", "minimal-ui", "browser"],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "iarc_rating_id": "e10b9a1c-9e5a-4b6f-8c9a-3e5b4a8c7d2f",
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"],
    "route_to": "existing-client"
  },
  "note_taking": {
    "new_note_url": "/notes/new"
  },
  "share_target": {
    "action": "/share-target/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "image",
          "accept": ["image/jpeg", "image/png", "image/webp"]
        }
      ]
    }
  },
  "splash_pages": {
    "default": "/splash.html",
    "dark": "/splash-dark.html"
  },
  "dark_mode": {
    "enabled": true,
    "default": "light",
    "color_scheme": "auto"
  },
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "text/markdown": [".md"],
        "text/html": [".html"],
        "text/plain": [".txt"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+trending",
      "url": "/share/?title=%s"
    },
    {
      "protocol": "mailto",
      "url": "/compose?to=%s"
    },
    {
      "protocol": "web+trendingwealth",
      "url": "/open?url=%s"
    }
  ],
  "url_handlers": [
    {
      "origin": "https://trendingwealth.com",
      "paths": ["/*"]
    }
  ],
  "dev": {
    "enabled": false,
    "icon": "/assets/images/dev-icon.png"
  },
  "prefer_related_applications": false,
  "serviceworker": {
    "src": "/sw.js",
    "scope": "/",
    "type": "classic",
    "update_via_cache": "none"
  }
}